		"daisyui": "5.5.19",
		"drizzle-kit": "0.31.10",
		"drizzle-orm": "0.45.2",
		"eslint": "10.3.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.17.1",
		"globals": "17.6.0",
		"leaflet": "1.9.4",
		"postgres": "3.4.9",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "3.5.2",
		"prettier-plugin-tailwindcss": "0.8.0",
		"sharp": "0.34.5",
		"sveaflet": "0.1.4",
		"svelte": "5.55.5",
